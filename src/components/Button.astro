---
interface Props {
  variant?: "primary" | "outline";
  href?: string;
  class?: string;
}

const { variant = "primary", href = "#", class: className = "" } = Astro.props;

const baseClasses =
  "inline-flex items-center justify-center px-6 py-3 rounded-lg font-medium text-base transition-all duration-200 cursor-pointer hover:scale-[1.02] active:scale-[0.98]";
const variants = {
  primary:
    "bg-gradient-to-r from-primary to-indigo text-white shadow-lg hover:shadow-[0_0_20px_rgba(1,112,185,0.5)]",
  outline:
    "border-2 border-primary text-primary hover:bg-primary hover:text-white hover:shadow-lg",
};
---

<a href={href} class:list={[baseClasses, variants[variant], className]}>
  <slot />
</a>
