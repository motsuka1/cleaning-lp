---
interface Props {
  variant?: "primary" | "outline";
  href?: string;
  class?: string;
}

const { variant = "primary", href = "#", class: className = "" } = Astro.props;

const baseClasses =
  "inline-flex items-center justify-center px-6 py-3 rounded-lg font-medium text-base transition-all duration-200 cursor-pointer";
const variants = {
  primary:
    "bg-primary text-white hover:bg-primary-dark shadow-lg hover:shadow-xl",
  outline:
    "border-2 border-primary text-primary hover:bg-primary hover:text-white",
};
---

<a href={href} class:list={[baseClasses, variants[variant], className]}>
  <slot />
</a>
