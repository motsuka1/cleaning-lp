---
const serviceLinks = [
  { label: "清掃報告", href: "#" },
  { label: "勤怠管理", href: "#" },
  { label: "ホームページ作成", href: "#" },
];

const companyLinks = [
  { label: "会社概要", href: "#" },
  { label: "採用情報", href: "#" },
  { label: "プライバシーポリシー", href: "#" },
  { label: "利用規約", href: "#" },
];

const supportLinks = [
  { label: "ヘルプセンター", href: "#" },
  { label: "お問い合わせ", href: "#contact" },
  { label: "資料ダウンロード", href: "#" },
  { label: "セミナー情報", href: "#" },
];
---

<footer class="bg-footer text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12">
      <!-- Logo & Address -->
      <div>
        <div class="flex items-center gap-2 mb-4">
          <div class="w-8 h-8 bg-primary rounded-lg flex items-center justify-center">
            <span class="text-white font-bold text-sm">C</span>
          </div>
          <span class="text-xl font-bold">
            Clean<span class="text-primary">AI</span>
          </span>
        </div>
        <p class="text-gray-400 text-sm leading-relaxed">
          〒100-0001<br />
          東京都千代田区千代田1-1-1<br />
          CleanAIビル 10F
        </p>
        <p class="text-gray-400 text-sm mt-3">
          TEL: 03-1234-5678
        </p>
      </div>

      <!-- Services -->
      <div>
        <h3 class="font-bold text-sm mb-4 text-gray-300">サービス</h3>
        <ul class="space-y-3">
          {
            serviceLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-gray-400 hover:text-white transition-colors text-sm"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h3 class="font-bold text-sm mb-4 text-gray-300">会社情報</h3>
        <ul class="space-y-3">
          {
            companyLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-gray-400 hover:text-white transition-colors text-sm"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Support -->
      <div>
        <h3 class="font-bold text-sm mb-4 text-gray-300">サポート</h3>
        <ul class="space-y-3">
          {
            supportLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-gray-400 hover:text-white transition-colors text-sm"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </div>

  <!-- Copyright -->
  <div class="border-t border-gray-800">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
      <p class="text-center text-gray-500 text-sm">
        &copy; 2026 CleanAI Inc. All rights reserved.
      </p>
    </div>
  </div>
</footer>
