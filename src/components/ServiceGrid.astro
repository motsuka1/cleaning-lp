---
import SectionHeading from "./SectionHeading.astro";

const services = [
  {
    title: "清掃報告",
    description:
      "写真を撮るだけでAIが清掃報告書を自動作成。手書き・Excel作業を大幅に削減し、レポート品質も向上。",
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>`,
    color: "primary",
  },
  {
    title: "勤怠管理",
    description:
      "スマホひとつで出退勤の打刻、シフト管理、給与計算まで完結。現場スタッフの負担を最小限に。",
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>`,
    color: "accent",
  },
  {
    title: "ホームページ作成",
    description:
      "清掃会社に特化したテンプレートで、集客できるホームページを最短5分で作成。SEO対策も万全。",
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"></path></svg>`,
    color: "primary",
  },
];
---

<section id="services" class="py-20 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="reveal">
      <SectionHeading
        title="CleanAIのサービス"
        subtitle="清掃業界のあらゆる課題を解決する3つのプロダクト"
      />
    </div>

    <div class="grid md:grid-cols-3 gap-8">
      {
        services.map((service) => (
          <div class="reveal group p-8 rounded-2xl border border-gray-100 hover:border-primary/20 hover:shadow-xl transition-all duration-300 bg-white">
            <div
              class={`w-14 h-14 rounded-xl flex items-center justify-center mb-6 ${
                service.color === "accent"
                  ? "bg-accent/10 text-accent"
                  : "bg-primary/10 text-primary"
              }`}
            >
              <Fragment set:html={service.icon} />
            </div>
            <h3 class="text-xl font-bold mb-3 group-hover:text-primary transition-colors">
              {service.title}
            </h3>
            <p class="text-text-secondary leading-relaxed">
              {service.description}
            </p>
            <a
              href="#"
              class="inline-flex items-center mt-4 text-primary font-medium text-sm hover:gap-2 transition-all"
            >
              詳しく見る
              <svg
                class="w-4 h-4 ml-1"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M9 5l7 7-7 7"
                />
              </svg>
            </a>
          </div>
        ))
      }
    </div>
  </div>
</section>
