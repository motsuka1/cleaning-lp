---
import SectionHeading from "./SectionHeading.astro";

const newsItems = [
  {
    date: "2026.02.15",
    category: "プレスリリース",
    title: "CleanAI、シリーズBで10億円の資金調達を実施",
  },
  {
    date: "2026.02.01",
    category: "アップデート",
    title: "清掃報告機能に多言語対応（英語・中国語）を追加",
  },
  {
    date: "2026.01.20",
    category: "イベント",
    title: "「清掃業界DXサミット 2026」に登壇決定",
  },
];
---

<section class="py-20 bg-white">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="reveal">
      <SectionHeading title="お知らせ" />
    </div>

    <div class="reveal space-y-0 divide-y divide-gray-100">
      {
        newsItems.map((item) => (
          <a
            href="#"
            class="flex flex-col sm:flex-row sm:items-center gap-2 sm:gap-6 py-5 hover:bg-bg-alt hover:translate-x-1 -mx-4 px-4 rounded-lg transition-all duration-300 group"
          >
            <time class="text-sm text-text-secondary flex-shrink-0">
              {item.date}
            </time>
            <span class="text-xs bg-primary/10 text-primary px-2 py-0.5 rounded-full font-medium flex-shrink-0 w-fit">
              {item.category}
            </span>
            <span class="text-text-body group-hover:text-primary transition-all duration-300">
              {item.title}
            </span>
          </a>
        ))
      }
    </div>
  </div>
</section>
