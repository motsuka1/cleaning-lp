---
const stats = [
  { value: "500社以上", label: "導入企業" },
  { value: "99.2%", label: "継続率" },
  { value: "98%", label: "顧客満足度" },
];

const logos = [
  "クリーンプロ株式会社",
  "美装サービス",
  "スマートクリーン",
  "ファシリティ東京",
  "グリーンケア",
  "ピュアクリーン",
  "メンテナンスワン",
  "ビルサポート",
];
---

<section class="py-16 bg-bg-alt">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Stats -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-12 reveal">
      {
        stats.map((stat) => (
          <div class="text-center">
            <p class="text-3xl md:text-4xl font-bold text-primary mb-1">
              {stat.value}
            </p>
            <p class="text-text-secondary font-medium">{stat.label}</p>
          </div>
        ))
      }
    </div>

    <!-- Logo Carousel -->
    <div class="overflow-hidden">
      <div class="logo-carousel flex gap-12 items-center w-max">
        {
          [...logos, ...logos].map((name) => (
            <div class="flex-shrink-0 px-4 py-2 bg-white rounded-lg shadow-sm border border-gray-100">
              <span class="text-sm text-text-secondary font-medium whitespace-nowrap">
                {name}
              </span>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
