---
import SectionHeading from "./SectionHeading.astro";

const reasons = [
  {
    title: "清掃業界に特化",
    description:
      "清掃業界の業務フローを徹底分析。現場が本当に必要とする機能だけを搭載しています。",
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"></path></svg>`,
  },
  {
    title: "導入・操作がかんたん",
    description:
      "最短即日で導入可能。スマホが使えれば誰でも操作できるシンプルなUI設計。",
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"></path></svg>`,
  },
  {
    title: "万全のセキュリティ",
    description:
      "ISO27001取得。データは国内サーバーで暗号化保存。安心してご利用いただけます。",
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>`,
  },
];
---

<section class="py-20 bg-bg-alt">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="reveal">
      <SectionHeading
        title="CleanAIが選ばれる理由"
        subtitle="清掃業界のプロフェッショナルに支持される3つの理由"
      />
    </div>

    <div class="grid md:grid-cols-3 gap-8">
      {
        reasons.map((reason) => (
          <div class="reveal text-center p-8 bg-white rounded-2xl shadow-sm hover:shadow-lg transition-shadow">
            <div class="w-16 h-16 bg-primary/10 rounded-2xl flex items-center justify-center mx-auto mb-6 text-primary">
              <Fragment set:html={reason.icon} />
            </div>
            <h3 class="text-xl font-bold mb-3">{reason.title}</h3>
            <p class="text-text-secondary leading-relaxed">
              {reason.description}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
