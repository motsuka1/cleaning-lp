---
import Button from "./Button.astro";
---

<section class="pt-24 pb-16 md:pt-32 md:pb-24 bg-gradient-to-br from-white via-blue-50/50 to-white overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid md:grid-cols-2 gap-12 items-center">
      <!-- Text -->
      <div class="reveal">
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-black leading-tight mb-6">
          AIで清掃業務を、<br />
          <span class="text-primary">もっとスマートに。</span>
        </h1>
        <p class="text-lg md:text-xl text-text-secondary mb-8 leading-relaxed">
          清掃報告・勤怠管理・ホームページ作成。<br class="hidden sm:inline" />
          清掃業界に特化したオールインワンAIプラットフォーム。
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <Button href="#contact" variant="primary" class="text-lg px-8 py-4">
            無料で資料をダウンロード
          </Button>
          <Button href="#contact" variant="outline" class="text-lg px-8 py-4">
            お問い合わせ
          </Button>
        </div>
      </div>

      <!-- Dashboard mockup -->
      <div class="reveal hidden md:block">
        <div class="bg-white rounded-2xl shadow-2xl border border-gray-100 p-6 relative">
          <div class="flex items-center gap-2 mb-4">
            <div class="w-3 h-3 rounded-full bg-red-400"></div>
            <div class="w-3 h-3 rounded-full bg-yellow-400"></div>
            <div class="w-3 h-3 rounded-full bg-green-400"></div>
            <span class="ml-2 text-xs text-text-secondary">CleanAI Dashboard</span>
          </div>
          <!-- Mock dashboard content -->
          <div class="space-y-4">
            <div class="flex items-center justify-between p-3 bg-bg-alt rounded-lg">
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 bg-primary/10 rounded-lg flex items-center justify-center">
                  <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
                </div>
                <div>
                  <p class="text-sm font-medium">清掃報告書 #1234</p>
                  <p class="text-xs text-text-secondary">自動生成完了</p>
                </div>
              </div>
              <span class="text-xs bg-accent/10 text-accent px-2 py-1 rounded-full font-medium">完了</span>
            </div>
            <div class="grid grid-cols-3 gap-3">
              <div class="p-3 bg-bg-alt rounded-lg text-center">
                <p class="text-2xl font-bold text-primary">156</p>
                <p class="text-xs text-text-secondary">今月の報告</p>
              </div>
              <div class="p-3 bg-bg-alt rounded-lg text-center">
                <p class="text-2xl font-bold text-accent">98%</p>
                <p class="text-xs text-text-secondary">出勤率</p>
              </div>
              <div class="p-3 bg-bg-alt rounded-lg text-center">
                <p class="text-2xl font-bold text-yellow-500">4.8</p>
                <p class="text-xs text-text-secondary">評価</p>
              </div>
            </div>
            <div class="p-3 bg-bg-alt rounded-lg">
              <div class="flex items-center justify-between mb-2">
                <p class="text-sm font-medium">今週の進捗</p>
                <p class="text-xs text-accent font-medium">85%</p>
              </div>
              <div class="w-full bg-gray-200 rounded-full h-2">
                <div class="bg-accent h-2 rounded-full" style="width: 85%"></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
